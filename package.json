{
  "name": "webpack-react-typescript-boilerplate",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DonAdam2/react-language-router-v6"
  },
  "description": "Webpack react boilerplate with typescript",
  "main": "index.js",
  "browserslist": [
    "ie >= 11",
    "last 2 version"
  ],
  "scripts": {
    "start": "node scripts/start.js",
    "build": "webpack --config buildTools/webpack.prod.js --progress --color",
    "build:serve": "serve dist --cors -p 8080",
    "analyze-bundle": "yarn build --json=stats.json && webpack-bundle-analyzer stats.json dist",
    "generate": "plop"
  },
